# Firebase — for sharing checklists/templates via Firestore
# Set VITE_FIREBASE_ENABLED=true to enable the sharing feature.
# Get values from Firebase Console → Project Settings → General → Your apps → Web.
VITE_FIREBASE_ENABLED=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
