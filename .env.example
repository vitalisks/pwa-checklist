# Firebase — for sharing checklists/templates via Firestore
# Set VITE_FIREBASE_ENABLED=true to enable the sharing feature.
# Get values from Firebase Console → Project Settings → General → Your apps → Web.
VITE_FIREBASE_ENABLED=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# OIDC Authentication — optional sign-in to protect shared documents
# Set VITE_OIDC_ENABLED=true to enable. Requires VITE_FIREBASE_ENABLED=true.
VITE_OIDC_ENABLED=
VITE_OIDC_AUTHORITY=
VITE_OIDC_CLIENT_ID=
VITE_OIDC_SCOPE=openid profile email
VITE_OIDC_REDIRECT_URI=
VITE_CUSTOM_TOKEN_ENDPOINT=
