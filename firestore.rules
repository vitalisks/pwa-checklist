rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Per-device inbox documents (inbox_{deviceId}). Only point reads/writes.
    // The deviceId is embedded in the document ID and in each entry's data,
    // providing path-to-content consistency validation.
    match /shared_payloads/{docId} {
      // matches() does a full string match in Firestore rules
      allow get: if docId.matches('inbox_.*');

      // Writes allowed for inbox_* docs (deviceId is a UUID, so path is unguessable)
      allow create, update: if docId.matches('inbox_.*');

      // Never delete the inbox document itself — entries are removed via field delete
      allow delete: if false;
    }

    // Collaborative checklist documents. Accessed by known checklistId only.
    // Discovery is via collaborationInvites in the inbox doc, not collection queries.
    match /collaborative_checklists/{checklistId} {
      allow get: if true;

      // Create: full document must include ownerDeviceId + collaborators
      allow create: if request.resource.data.keys().hasAll(['ownerDeviceId', 'collaborators'])
        && request.resource.data.collaborators is list
        && request.resource.data.collaborators.size() >= 1;

      // Update: allowed once the doc exists (handles field-level updateDoc calls)
      allow update: if true;

      allow delete: if true;
    }
  }
}
